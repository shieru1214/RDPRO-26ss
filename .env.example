# Copy this file to .env and fill in local secrets.
# .env is ignored by git.

# Use Qwen/DashScope for Module 1 natural-language parsing.
JIAOZI_LLM_PROVIDER=qwen
JIAOZI_DASHSCOPE_API_KEY=replace_with_dashscope_key
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
M1_QWEN_MODEL=qwen-plus

# Use Qwen for Module 4 model.py generation.
# Set to none for template-only generation, or qwen/openai/vertex for a provider.
M4_LLM_PROVIDER=qwen
M4_QWEN_MODEL=qwen-plus

# Optional OpenAI settings.
# JIAOZI_LLM_PROVIDER=openai
# OPENAI_API_KEY=replace_with_your_new_key
# M1_OPENAI_MODEL=gpt-4o
# M4_LLM_PROVIDER=openai
# M4_OPENAI_MODEL=gpt-4o
